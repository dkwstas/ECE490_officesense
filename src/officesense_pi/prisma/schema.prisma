generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String  @id @default(uuid())
  firstName     String
  lastName      String
  faceEmbedding Bytes?
  tag           Tag?
}

model Tag {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Room {
  id   String @id @default(uuid())
  name String
}
